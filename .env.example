# ============================================================
# Virteem Companion - Local mode configuration
# ============================================================
#
# Please copy this file to .env:
#   cp .env.example .env
#
# Then update the values below.
# ============================================================

# --------------------------------------------------
# USE_GPU (optional - default: yes)
# --------------------------------------------------
# yes: uses docker-compose.gpu.yml to reserve the NVIDIA GPU
# no : starts Ollama without GPU reservation
#
USE_GPU=yes

# --------------------------------------------------
# USE_NGROK (optional - default: yes)
# --------------------------------------------------
# yes: also starts the Ngrok tunnel
# no : starts Ollama locally only
#
USE_NGROK=yes

# --------------------------------------------------
# NGROK_AUTHTOKEN (required if USE_NGROK=yes)
# --------------------------------------------------
# Your Ngrok authentication token.
# Please create a free account at https://ngrok.com
# then retrieve your token from:
#   https://dashboard.ngrok.com/get-started/your-authtoken
#
NGROK_AUTHTOKEN=your_ngrok_token_here

# --------------------------------------------------
# MODEL (optional - default: llama3.2:3b)
# --------------------------------------------------
# Name of the Ollama model to pull and use.
#
# Lightweight models (CPU, no GPU):
#   qwen2.5:0.5b       ~400 MB, ~1 GB RAM, tool calling OK
#   qwen2.5:1.5b       ~1 GB,   ~2 GB RAM, tool calling OK (recommended for CPU)
#   qwen2.5:3b         ~2 GB,   ~4 GB RAM, tool calling OK
#   llama3.2:3b        ~2 GB,   ~4 GB RAM, tool calling OK
#
# Higher-performance models (NVIDIA GPU recommended):
#   mistral             ~4 GB,   ~8 GB RAM, strong French support
#   llama3.1            ~5 GB,  ~10 GB RAM, strong general performance
#   qwen2.5             ~4 GB,   ~8 GB RAM, multilingual
#   llama3.1:70b       ~40 GB,  ~48 GB RAM, production usage
#
# Hugging Face model (GGUF format):
#   hf.co/TheBloke/Mistral-7B-Instruct-v0.2-GGUF
#
MODEL=qwen2.5:1.5b

# --------------------------------------------------
# VIRTEEM_TOKEN (optional)
# --------------------------------------------------
# Security token used to protect model access through Ngrok.
#
# If this variable is NOT defined:
#   -> A random token is generated automatically at each start
#   -> It is displayed in the terminal
#
# If this variable IS defined:
#   -> The same token is reused at each start
#   -> You will not need to reconfigure it in Virteem Companion after a restart
#
# Uncomment the line below before configuring it
# VIRTEEM_TOKEN=your_custom_token_here
