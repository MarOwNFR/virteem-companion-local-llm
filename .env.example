# ============================================================
# Virteem Companion — Configuration du mode local
# ============================================================
#
# Copiez ce fichier en .env :
#   cp .env.example .env
#
# Puis renseignez les valeurs ci-dessous.
# ============================================================

# --------------------------------------------------
# NGROK_AUTHTOKEN (obligatoire)
# --------------------------------------------------
# Votre token d'authentification Ngrok.
# Créez un compte gratuit sur https://ngrok.com
# puis récupérez votre token sur :
#   https://dashboard.ngrok.com/get-started/your-authtoken
#
NGROK_AUTHTOKEN=votre_token_ngrok_ici

# --------------------------------------------------
# MODEL (optionnel — défaut : llama3.2:3b)
# --------------------------------------------------
# Nom du modèle Ollama à télécharger et utiliser.
#
# Modèles légers (CPU, sans GPU) :
#   qwen2.5:0.5b       ~400 Mo, ~1 Go RAM, tool calling OK
#   qwen2.5:1.5b       ~1 Go,   ~2 Go RAM, tool calling OK (recommandé CPU)
#   qwen2.5:3b         ~2 Go,   ~4 Go RAM, tool calling OK
#   llama3.2:3b         ~2 Go,   ~4 Go RAM, tool calling OK
#
# Modèles performants (GPU NVIDIA recommandé) :
#   mistral             ~4 Go,   ~8 Go RAM, bon en français
#   llama3.1            ~5 Go,  ~10 Go RAM, performant
#   qwen2.5             ~4 Go,   ~8 Go RAM, multilingue
#   llama3.1:70b       ~40 Go,  ~48 Go RAM, production
#
# Modèle HuggingFace (format GGUF) :
#   hf.co/TheBloke/Mistral-7B-Instruct-v0.2-GGUF
#
MODEL=qwen2.5:1.5b

# --------------------------------------------------
# VIRTEEM_TOKEN (optionnel)
# --------------------------------------------------
# Token de sécurité pour protéger l'accès au modèle via Ngrok.
#
# Si cette variable N'EST PAS définie :
#   → Un token aléatoire est généré automatiquement à chaque lancement
#   → Il est affiché dans le terminal (vous devrez le recopier à chaque fois)
#
# Si cette variable EST définie :
#   → Le même token est réutilisé à chaque lancement
#   → Pas besoin de le reconfigurer dans Virteem Companion après un redémarrage
#
# VIRTEEM_TOKEN=mon-token-personnalise-ici
